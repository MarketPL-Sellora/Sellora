# ==========================================
# SELLORA: ENVIRONMENT VARIABLES TEMPLATE
# ==========================================
# ІНСТРУКЦІЯ:
# 1. Скопіюйте цей файл і назвіть його `.env`
# 2. Файл `.env` додайте у .gitignore!
# 3. Заповніть ваші реальні ключі.
# ==========================================

# --- [ БАЗА ДАНИХ (PostgreSQL) ] ---
DB_USER=postgres
DB_PASSWORD=your_secure_db_password
DB_NAME=sellora_db

# --- [ PGADMIN (Веб-інтерфейс БД) ] ---
PGADMIN_EMAIL=admin@sellora.com
PGADMIN_PASSWORD=admin_secure_password

# --- [ CLOUDINARY (Зберігання картинок) ] ---
# Формат: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# --- [ LIQPAY (Платіжна система) ] ---
LIQPAY_PUBLIC_KEY=sandbox_your_public_key
LIQPAY_PRIVATE_KEY=sandbox_your_private_key

# --- [ БЕЗПЕКА (JWT) ] ---
# (Якщо у вас є JWT токени, додайте їх сюди також)
JWT_SECRET=your_super_secret_jwt_key_that_must_be_long_enough
JWT_EXPIRATION_MS=86400000
